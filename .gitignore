dist/
build/

# ── App runtime files ─────────────────────────────────────────────────────────
settings.json          # user-specific; never commit personal config

# ── IDE / OS ──────────────────────────────────────────────────────────────────
.vscode/
.idea/
*.suo
*.user
.DS_Store
Thumbs.db
desktop.ini

# ── Logs & temp ───────────────────────────────────────────────────────────────
*.log
*.tmp
*.bak
